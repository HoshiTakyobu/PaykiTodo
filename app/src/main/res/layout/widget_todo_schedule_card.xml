<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_todo_item_background"
    android:gravity="top"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:id="@+id/widget_schedule_date_block"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_schedule_month"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/widget_text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_schedule_weekday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textColor="@color/widget_event_blue"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_schedule_day"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="center"
            android:textColor="@color/widget_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_schedule_today_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_schedule_inner_background"
            android:ellipsize="end"
            android:maxLines="2"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:textColor="@color/widget_text_muted"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/widget_schedule_today_event_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:minHeight="58dp"
            android:orientation="horizontal"
            android:paddingTop="7dp"
            android:paddingEnd="6dp"
            android:paddingBottom="7dp">

            <ImageView
                android:id="@+id/widget_schedule_today_event_1_strip"
                android:layout_width="5dp"
                android:layout_height="50dp"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/widget_vertical_pill" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_schedule_today_event_1_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_schedule_today_event_1_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/widget_schedule_today_event_1_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/widget_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_schedule_today_event_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:minHeight="58dp"
            android:orientation="horizontal"
            android:paddingTop="7dp"
            android:paddingEnd="6dp"
            android:paddingBottom="7dp">

            <ImageView
                android:id="@+id/widget_schedule_today_event_2_strip"
                android:layout_width="5dp"
                android:layout_height="50dp"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/widget_vertical_pill" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_schedule_today_event_2_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_schedule_today_event_2_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/widget_schedule_today_event_2_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/widget_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_schedule_tomorrow_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="明天"
            android:textColor="@color/widget_text_muted"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_schedule_tomorrow_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/widget_schedule_inner_background"
            android:ellipsize="end"
            android:maxLines="2"
            android:paddingStart="12dp"
            android:paddingTop="9dp"
            android:paddingEnd="12dp"
            android:paddingBottom="9dp"
            android:textColor="@color/widget_header"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/widget_schedule_tomorrow_event_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:minHeight="58dp"
            android:orientation="horizontal"
            android:paddingTop="7dp"
            android:paddingEnd="6dp"
            android:paddingBottom="7dp">

            <ImageView
                android:id="@+id/widget_schedule_tomorrow_event_1_strip"
                android:layout_width="5dp"
                android:layout_height="50dp"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/widget_vertical_pill" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_schedule_tomorrow_event_1_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_schedule_tomorrow_event_1_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/widget_schedule_tomorrow_event_1_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/widget_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_schedule_tomorrow_event_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:minHeight="58dp"
            android:orientation="horizontal"
            android:paddingTop="7dp"
            android:paddingEnd="6dp"
            android:paddingBottom="7dp">

            <ImageView
                android:id="@+id/widget_schedule_tomorrow_event_2_strip"
                android:layout_width="5dp"
                android:layout_height="50dp"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/widget_vertical_pill" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_schedule_tomorrow_event_2_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_schedule_tomorrow_event_2_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/widget_schedule_tomorrow_event_2_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/widget_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
