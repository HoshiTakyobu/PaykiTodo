<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_countdown_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_board_background"
    android:padding="10dp">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.22"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_dashboard_bg_image" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/widget_countdown_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="倒数日"
            android:textColor="@color/widget_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_countdown_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="关键目标不要等到最后一天"
            android:textColor="@color/widget_text_muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_countdown_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/widget_task_meta_background"
            android:includeFontPadding="false"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:text="0 项"
            android:textColor="@color/widget_header"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_countdown_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/widget_todo_soft_card_background"
            android:padding="14dp"
            android:text="还没有设置倒数日。编辑待办或日程时打开倒数日开关。"
            android:textColor="@color/widget_text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/widget_countdown_row_1"
            style="@style/WidgetCountdownRow"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/widget_countdown_check_1"
                style="@style/WidgetCountdownCheck" />

            <LinearLayout style="@style/WidgetCountdownTimeBlock">

                <TextView
                    android:id="@+id/widget_countdown_days_1"
                    style="@style/WidgetCountdownDays" />

                <TextView
                    android:id="@+id/widget_countdown_remaining_1"
                    style="@style/WidgetCountdownRemaining" />
            </LinearLayout>

            <ImageView
                android:id="@+id/widget_countdown_strip_1"
                style="@style/WidgetCountdownStrip" />

            <LinearLayout style="@style/WidgetCountdownTextBlock">

                <TextView
                    android:id="@+id/widget_countdown_title_1"
                    style="@style/WidgetCountdownItemTitle" />

                <TextView
                    android:id="@+id/widget_countdown_meta_1"
                    style="@style/WidgetCountdownItemMeta" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_countdown_row_2"
            style="@style/WidgetCountdownRow">

            <TextView
                android:id="@+id/widget_countdown_check_2"
                style="@style/WidgetCountdownCheck" />

            <LinearLayout style="@style/WidgetCountdownTimeBlock">

                <TextView
                    android:id="@+id/widget_countdown_days_2"
                    style="@style/WidgetCountdownDays" />

                <TextView
                    android:id="@+id/widget_countdown_remaining_2"
                    style="@style/WidgetCountdownRemaining" />
            </LinearLayout>

            <ImageView
                android:id="@+id/widget_countdown_strip_2"
                style="@style/WidgetCountdownStrip" />

            <LinearLayout style="@style/WidgetCountdownTextBlock">

                <TextView
                    android:id="@+id/widget_countdown_title_2"
                    style="@style/WidgetCountdownItemTitle" />

                <TextView
                    android:id="@+id/widget_countdown_meta_2"
                    style="@style/WidgetCountdownItemMeta" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_countdown_row_3"
            style="@style/WidgetCountdownRow">

            <TextView
                android:id="@+id/widget_countdown_check_3"
                style="@style/WidgetCountdownCheck" />

            <LinearLayout style="@style/WidgetCountdownTimeBlock">

                <TextView
                    android:id="@+id/widget_countdown_days_3"
                    style="@style/WidgetCountdownDays" />

                <TextView
                    android:id="@+id/widget_countdown_remaining_3"
                    style="@style/WidgetCountdownRemaining" />
            </LinearLayout>

            <ImageView
                android:id="@+id/widget_countdown_strip_3"
                style="@style/WidgetCountdownStrip" />

            <LinearLayout style="@style/WidgetCountdownTextBlock">

                <TextView
                    android:id="@+id/widget_countdown_title_3"
                    style="@style/WidgetCountdownItemTitle" />

                <TextView
                    android:id="@+id/widget_countdown_meta_3"
                    style="@style/WidgetCountdownItemMeta" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
