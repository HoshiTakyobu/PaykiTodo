# PaykiTodo local release-signing template.
#
# Copy this file to:
#
#   keystore.properties
#
# Then fill keystore.properties locally. Do not commit keystore.properties.
#
# The first four fields are read by Gradle when building release APKs.
storeFile=release/PaykiTodo-release.jks
storePassword=REPLACE_WITH_STORE_PASSWORD
keyAlias=paykitodo
keyPassword=REPLACE_WITH_KEY_PASSWORD

# The fields below are for generating the keystore with keytool.
# They are not required by Gradle after the keystore already exists.
validityDays=10000
dnameCN=REPLACE_WITH_DEVELOPER_OR_PROJECT_NAME
dnameOU=PaykiTodo
dnameO=Personal
dnameL=REPLACE_WITH_CITY
dnameST=REPLACE_WITH_PROVINCE
dnameC=CN
